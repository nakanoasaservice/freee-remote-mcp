# ローカル開発用の環境変数テンプレート
# コピーして .dev.vars を作成し、値を設定してください
# 本番環境: WORKER_URL, FREEE_CLIENT_ID は wrangler.jsonc の vars に、
#           FREEE_CLIENT_SECRET は wrangler secret put で設定

# freee OAuth アプリケーションの認証情報
# 取得先: https://secure.freee.co.jp/oauth/applications
FREEE_CLIENT_ID=your_client_id
FREEE_CLIENT_SECRET=your_client_secret

# Worker の URL（ローカル開発時は localhost）
WORKER_URL="http://localhost:8787"
