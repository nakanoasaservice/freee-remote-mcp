{
	"name": "freee-remote-mcp",
	"version": "0.0.0",
	"license": "Apache-2.0",
	"private": true,
	"cloudflare": {
		"bindings": {
			"FREEE_CLIENT_ID": {
				"description": "freee OAuth アプリの [クライアント ID](https://secure.freee.co.jp/oauth/applications) を入力"
			},
			"FREEE_CLIENT_SECRET": {
				"description": "freee OAuth アプリの [クライアントシークレット](https://secure.freee.co.jp/oauth/applications) を入力"
			},
			"WORKER_URL": {
				"description": "デプロイ後の Worker URL（例: https://freee-remote-mcp.xxx.workers.dev）。末尾スラッシュなし"
			}
		}
	},
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"check:fix": "biome check --write",
		"check": "biome check"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@cloudflare/vitest-pool-workers": "^0.13.0",
		"@types/node": "^25.5.0",
		"typescript": "^5.5.2",
		"vitest": "^4.1.0",
		"wrangler": "^4.73.0"
	},
	"dependencies": {
		"@cloudflare/workers-oauth-provider": "^0.3.0",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"hono": "^4.12.8",
		"zod": "^4.3.6"
	}
}
